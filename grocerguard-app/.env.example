# Flask
SECRET_KEY=change-me-to-a-long-random-secret

# Cloud Spanner (leave blank to fall back to SQLite for local dev)
SPANNER_PROJECT_ID=your-gcp-project-id
SPANNER_INSTANCE_ID=your-spanner-instance-id
SPANNER_DATABASE_ID=grocerguard

# Google Cloud Storage (for product images)
GCS_BUCKET_NAME=your-gcs-bucket-name

# Local dev only — path to service account JSON.
# On Cloud Run, leave unset and use the attached service account instead.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Email (for password reset)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Base URL for reset links (set to your Cloud Run URL in production)
APP_BASE_URL=https://your-cloud-run-url
